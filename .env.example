# --- Datenbank ---
DB_USER=streetfiles
DB_PASSWORD=streetfiles
DB_DATABASE=streetfiles

# --- Directus ---
DIRECTUS_SECRET=replace-with-a-secure-random-string-min-32-chars
ADMIN_EMAIL=admin@streetfiles.local
ADMIN_PASSWORD=changeme
DIRECTUS_PUBLIC_URL=http://localhost:8056

# --- Frontend (Next.js) ---
# Diese Werte in frontend/.env.local kopieren
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8056
# Token eines Directus-Service-Account mit Lesezugriff
DIRECTUS_TOKEN=
# JWT für Session-Token (min. 32 Zeichen, sicher zufällig generieren)
JWT_SECRET=replace-with-secure-random-string-min-32-chars
# Salt für Week-Hash (Zeitstempel-Minimierung)
WEEK_HASH_SECRET=replace-with-another-secure-random-string
